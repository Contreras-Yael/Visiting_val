{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "types": ["node"],
    
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "strict": true,
    
    // Desactiva esto por ahora para evitar errores de importación de tipos
    "verbatimModuleSyntax": false, 
    "isolatedModules": true,
    
    "sourceMap": true
  }
}